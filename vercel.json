{
  "redirects": [
    { "source": "/team", "destination": "/about#team", "permanent": true },
    { "source": "/awards", "destination": "/about#awards", "permanent": true },
    { "source": "/media", "destination": "/about#media", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/eng/index.html" },
    { "source": "/:path((?!eng|pl|css|img|js|fonts).+)", "destination": "/eng/:path" }
  ],
  "headers": [
    {
      "source": "/img/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
